# ============================================================
# .gitignore — US Bulk Supply Chain Reporting Platform
# Rule: Code, config, docs, small reference files go in git.
#        Large data files (>50MB), pipeline outputs, raw
#        downloads, and database files stay LOCAL ONLY.
# ============================================================

# --- Archives & compressed files ---
*.zip
*.gz
*.tar
*.tar.gz
*.7z
*.rar

# --- Database files ---
*.db
*.duckdb
*.duckdb.wal
*.sqlite
*.mdb

# --- Large binary files ---
*.bin
*.dat

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# --- Virtual environments ---
venv/
ENV/
env/

# --- IDEs ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS ---
.DS_Store
Thumbs.db

# --- Generated report output ---
04_REPORTS/*/output/

# ============================================================
# LARGE DATA FILES — kept local, never pushed to GitHub
# These are downloaded/generated data artifacts that can be
# regenerated by running the toolset pipelines.
# ============================================================

# --- Vessel intelligence pipeline outputs (650-770MB each) ---
02_TOOLSETS/vessel_intelligence/src/pipeline/*/phase_*_output.csv
02_TOOLSETS/vessel_intelligence/src/pipeline/phase_07_enrichment/test/sample_*.csv

# --- Facility registry raw data (downloaded from EPA FRS) ---
02_TOOLSETS/facility_registry/data/raw/
02_TOOLSETS/facility_registry/data/backups/

# --- Rail cost model: waybill historical data (downloaded from STB) ---
02_TOOLSETS/rail_cost_model/analytics/data/waybill_historical/extracted_*/
02_TOOLSETS/rail_cost_model/analytics/data/waybill_historical/*.csv

# --- Rail cost model: large reference data ---
02_TOOLSETS/rail_cost_model/data/reference/stb_rates/cement/waybill_cement_raw.json
02_TOOLSETS/rail_cost_model/data/reference/stb_rates/cement/epa_cement_facilities.json

# --- Vessel voyage analysis: large result files ---
02_TOOLSETS/vessel_voyage_analysis/results_*/event_log.csv

# --- State rail plan PDFs (large, downloaded) ---
02_TOOLSETS/rail_cost_model/data/state_rail_plans/*.pdf

# --- Barge cost model: large data files ---
02_TOOLSETS/barge_cost_model/forecasting/data/raw/*.csv
02_TOOLSETS/barge_cost_model/forecasting/data/processed/*.csv

# --- Policy analysis: large HTML downloads ---
02_TOOLSETS/policy_analysis/data/raw/other_sources/*.html

# --- Specific large files ---
03_COMMODITY_MODULES/cement/market_intelligence/tampa_study/data/epa/echo_exporter.zip
